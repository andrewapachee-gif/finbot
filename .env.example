TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username

# AI Provider (choose one)
OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_claude_key
# MISTRAL_API_KEY=your_mistral_key

# AI Model
AI_MODEL=gpt-4o-mini
# AI_MODEL=claude-3-haiku-20240307
# AI_MODEL=mistral-small-latest

# Bot Behavior
POSTING_MODE=auto  # auto, queue, or manual
DAILY_DIGEST_TIME=09:00
BREAKING_NEWS_THRESHOLD=0.8
MAX_POSTS_PER_DAY=10

# Content Filtering
MIN_ARTICLE_RELEVANCE=0.6
SENTIMENT_ANALYSIS=true
EXTRACT_TICKERS=true

# Features
ENABLE_POLLS=true
ENABLE_WEEKLY_ROUNDUP=true
WEEKLY_ROUNDUP_DAY=Sunday
WEEKLY_ROUNDUP_TIME=18:00

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/finbot.log
