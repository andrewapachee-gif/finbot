{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["ffmpeg", "python3"],
          "aptPackages": ["ffmpeg", "ffprobe"]
        },
        "build": {
          "cmds": ["pip install -r requirements.txt"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python src/main.py",
    "restartPolicy": {
      "type": "ON_FAILURE",
      "maxRetries": 10
    },
    "healthcheck": {
      "path": "/health",
      "port": 8080
    }
  }
}